# Reusable-packages monorepo — never commit secret material.
# (This package AUDITS for committed secrets; it must not become the leak.)
.env
.env.*
!.env.example
*.pem
*.key
.DS_Store
__pycache__/
*.pyc
node_modules/

# Audit runtime artifacts — reports are generated, not versioned.
# (audit now lives under components/Claude/audit/ after the components/ restructure;
#  de-anchored so runtime artifacts stay ignored wherever a copy of audit lands —
#  including assembled brick mirrors under bricks/*/components/.)
**/audit/**/*.report.json
**/audit/.runtime/
