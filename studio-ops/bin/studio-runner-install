#!/usr/bin/env bash
# studio-runner-install — idempotent host wiring for the ACHILLES queue runner.
#
# Prefers systemd (service + Persistent timer); falls back to a cron line when
# only cron exists; prints manual instructions when neither is available (e.g.
# the dev container). Safe to re-run — every step is check-then-apply.
#
# The runner itself performs NO guarded writes (dry-run agents + queue/heartbeat
# bookkeeping only) — arming any deferred plan stays a human/main-session step.
set -euo pipefail

HERE="$(cd "$(dirname "$0")/.." && pwd)"
UNIT_DIR=/etc/systemd/system
ENV_DIR=/etc/achilles
ENV_FILE="$ENV_DIR/queue-runner.env"
RUNNER_USER=achilles-runner

say() { printf '%s\n' "$*"; }

# --- credentials file (both backends need it) -------------------------------
install_env() {
  mkdir -p "$ENV_DIR"
  if [ ! -f "$ENV_FILE" ]; then
    install -m 0600 "$HERE/systemd/queue-runner.env.example" "$ENV_FILE"
    say "created $ENV_FILE from example — FILL IN the values (0600, root-owned)."
  else
    chmod 0600 "$ENV_FILE"
    say "$ENV_FILE present (perms enforced 0600)."
  fi
}

if command -v systemctl >/dev/null 2>&1 && [ -d /run/systemd/system ]; then
  say "backend: systemd"
  install_env
  # Dedicated non-root user (hardening checklist item 3 from the validation).
  if ! id -u "$RUNNER_USER" >/dev/null 2>&1; then
    useradd --system --no-create-home --shell /usr/sbin/nologin "$RUNNER_USER"
    say "created system user $RUNNER_USER"
  fi
  install -m 0644 "$HERE/systemd/achilles-queue-runner.service" "$UNIT_DIR/"
  install -m 0644 "$HERE/systemd/achilles-queue-runner.timer" "$UNIT_DIR/"
  systemctl daemon-reload
  systemctl enable --now achilles-queue-runner.timer
  say "enabled achilles-queue-runner.timer (boot +2min, every 15min, Persistent)."
elif command -v crontab >/dev/null 2>&1; then
  say "backend: cron (no systemd) — catch-up comes from the durable queue itself"
  install_env
  LINE="*/15 * * * * cd /studio/clients/_ops-agents && set -a && . $ENV_FILE && set +a && npx tsx agents/queue-runner.ts >> /var/log/achilles-queue-runner.log 2>&1"
  ( crontab -l 2>/dev/null | grep -v 'achilles-queue-runner' ; echo "# achilles-queue-runner"; echo "$LINE" ) | crontab -
  say "installed cron line (every 15min)."
else
  say "NEITHER systemd nor cron available on this host."
  say "Run one poll cycle manually with:"
  say "  cd /studio/clients/_ops-agents && set -a && . $ENV_FILE && set +a && npx tsx agents/queue-runner.ts"
  exit 0
fi
