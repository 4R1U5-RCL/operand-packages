# /etc/achilles/queue-runner.env — runner credentials (install as root:root 0600).
# Copy, fill, and NEVER commit a filled copy. The runner reads these by
# reference; values are never logged or written into reports.
#
# Supabase project hosting ops_task_queue + device_heartbeats:
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
# Stable device identity for claimed_by / device_heartbeats (defaults to hostname):
OPS_DEVICE_ID=achilles-primary
