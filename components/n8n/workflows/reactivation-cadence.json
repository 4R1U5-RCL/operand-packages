      "parameters": {
        "language": "javaScript",
        "jsCode": "const items = $input.all();\nconst out = [];\nfor (const it of items) {\n  const resp = it.json || {};\n  let rows = (function(__b){ if (__b && typeof __b === 'object') return __b; const __s = String(__b ?? '').trim(); if (!__s) return []; try { return JSON.parse(__s); } catch (__e) { return []; } })(resp.body);\n  if (!Array.isArray(rows)) rows = rows ? [rows] : [];\n  for (const r of rows) {\n    if (!r || typeof r !== 'object') continue;\n    const c = (r.contact && typeof r.contact === 'object') ? r.contact : {};\n    out.push({ json: {\n      __event: {\n        id: r.id != null ? r.id : null,\n        contact_id: r.contact_id != null ? r.contact_id : null,\n        channel: (r.channel || '').toString().toLowerCase() || null,\n        step: r.step != null ? r.step : null,\n        template_copy: r.template_copy != null ? r.template_copy : '',\n        subject: r.subject != null ? r.subject : null,\n      },\n      __contact: {\n        id: c.id != null ? c.id : (r.contact_id != null ? r.contact_id : null),\n        timezone: c.timezone != null ? c.timezone : null,\n        email: c.email != null ? c.email : null,\n        phone: c.phone != null ? c.phone : null,\n        name: c.name != null ? c.name : null,\n        status: c.status != null ? c.status : null,\n      },\n      // the copy actually delivered — template_copy until the seam personalises it.\n      __copy: r.template_copy != null ? r.template_copy : '',\n    } });\n  }\n}\nreturn out;"
      },
