        0
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const START = 9;\nconst END = 21;\nconst localHour = (tz) => {\n  if (!tz) return null;\n  try {\n    const s = new Intl.DateTimeFormat('en-US', { timeZone: String(tz), hour: 'numeric', hour12: false }).format(new Date());\n    const h = parseInt(String(s).replace(/[^0-9]/g, ''), 10);\n    return Number.isFinite(h) ? (h % 24) : null;\n  } catch (e) { return null; }\n};\nconst items = $input.all();\nconst out = [];\nfor (const it of items) {\n  const j = it.json;\n  const h = localHour(j.__contact && j.__contact.timezone);\n  // Unresolved tz (h === null) → NOT ok: gate the send (defer), never guess.\n  const ok = (h !== null) && (h >= START) && (h < END);\n  out.push({ json: Object.assign({}, j, { __quiet_ok: ok }) });\n}\nreturn out;"
      }
